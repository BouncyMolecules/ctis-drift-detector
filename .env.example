# Copy to .env and fill in values. Never commit .env.

# Logging: DEBUG, INFO, WARNING, ERROR
CTIS_DRIFT_LOG_LEVEL=INFO

# CTIS API (placeholder — replace with real base URL and auth)
CTIS_API_BASE_URL=https://api.example.com/ctis
CTIS_API_TIMEOUT_SECONDS=30
# CTIS_API_TOKEN=

# SQLite database path (relative to project root or absolute)
CTIS_DRIFT_DATABASE_URL=sqlite:///data/ctis_drift.db

# Optional feature flags
CTIS_DRIFT_ENABLE_MOCK_API=false
